# ---------------------------------------------------------------------------
# Travel affiliate site — environment variables
# Copy to .env.local and fill in. Never commit real values.
# ---------------------------------------------------------------------------

# Public site URL (used for canonical, hreflang, sitemap, OG)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Affiliate partner IDs (Phase 4) -------------------------------------
NEXT_PUBLIC_TRAVELPAYOUTS_MARKER=""
NEXT_PUBLIC_STAY22_ID=""
NEXT_PUBLIC_GETYOURGUIDE_PARTNER_ID=""
NEXT_PUBLIC_VIATOR_PARTNER_ID=""
NEXT_PUBLIC_DISCOVERCARS_AFFILIATE_ID=""

# --- Content / image provider APIs (Phase 2-4) ---------------------------
UNSPLASH_ACCESS_KEY=""
PEXELS_API_KEY=""
GETYOURGUIDE_API_KEY=""
VIATOR_API_KEY=""

# --- Supabase (email subscriptions, click log, tool data cache) ----------
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- Analytics (Phase 7) -------------------------------------------------
# Switch provider via env: "plausible" | "ga4" | "none"
NEXT_PUBLIC_ANALYTICS_PROVIDER="none"
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
NEXT_PUBLIC_GA4_ID=""
