# --- Supabase (data + auth ONLY, never media) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# --- App ---
# Absolute URL of the deployed app (used for magic-link redirects and public gallery links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Secret for HMAC-signed gallery-unlock cookies (password-protected galleries)
GALLERY_UNLOCK_SECRET=change-me-long-random-string

# --- Storage (Cloudflare R2, zero-egress; swappable via STORAGE_PROVIDER) ---
STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET=gallery-media
