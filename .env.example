# --- Supabase (data + auth ONLY, never media) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service-role key — ONLY for billing routes (webhook has no user session).
# Keep it out of the browser at all costs.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- App ---
# Absolute URL of the deployed app (used for magic-link redirects and public gallery links)
NEXT_PUBLIC_APP_URL=https://proiav.space
# Secret for HMAC-signed gallery-unlock cookies (password-protected galleries)
GALLERY_UNLOCK_SECRET=change-me-long-random-string

# --- Storage (Cloudflare R2, zero-egress; swappable via STORAGE_PROVIDER) ---
STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET=gallery-media

# --- Payments (LiqPay for the UA market; swappable via PAYMENT_PROVIDER) ---
# Billing UI shows a "not connected yet" notice until these are set.
PAYMENT_PROVIDER=liqpay
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=

# --- Booking notifications (optional; bookings work without email) ---
# Resend-compatible API. EMAIL_FROM like "Booking <booking@yourdomain>"
RESEND_API_KEY=
EMAIL_FROM=

# --- SEO ---
# Google Search Console verification code (content of the meta tag)
GOOGLE_SITE_VERIFICATION=

# --- Backblaze B2 (heavy tiers 500 GB+; switch with STORAGE_PROVIDER=b2) ---
B2_REGION=
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=
